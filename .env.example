# 国内AI情報チャンネルのWebhook URL
DISCORD_WEBHOOK_DOMESTIC=https://discord.com/api/webhooks/xxxxx/yyyyy

# 海外研究・話題（HackerNews）チャンネルのWebhook URL
DISCORD_WEBHOOK_HACKERNEWS=https://discord.com/api/webhooks/xxxxx/yyyyy

# 海外AIニュースチャンネルのWebhook URL
DISCORD_WEBHOOK_INTERNATIONAL=https://discord.com/api/webhooks/xxxxx/yyyyy

# 1回の実行で通知する最大件数（チャンネルごと）
MAX_NOTIFY_PER_RUN=5

# HackerNewsの最低ポイント数（これ未満は無視）
MIN_HN_POINTS=10
